<header class="topbar">

    <div class="topbar-left">
        <button type="button" class="menu-toggle" @onclick="ToggleMenu">
            <i class="bi bi-list"></i>
        </button>

        <h1>@Titulo</h1>
    </div>

    <div class="user-box">

        <div class="user-text">
            <strong>@NombreUsuario</strong>
            <span>@RolUsuario</span>
        </div>

        <div class="avatar">
            <i class="bi bi-person-fill"></i>
        </div>

    </div>

</header>

<style>
    .topbar {
        height: 88px;
        background: #3561ad;
        color: white;
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0 28px;
        width: 100%;
    }

    .topbar-left {
        display: flex;
        align-items: center;
        gap: 24px;
    }

    .menu-toggle {
        border: none;
        background: transparent;
        color: white;
        font-size: 36px;
        cursor: pointer;
        display: flex;
        align-items: center;
        padding: 0;
    }

        .menu-toggle:hover {
            transform: scale(1.08);
        }

    .topbar h1 {
        font-size: 30px;
        font-weight: 800;
        margin: 0;
    }

    .user-box {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .user-text {
        display: flex;
        flex-direction: column;
        text-align: right;
        line-height: 1.2;
    }

        .user-text strong {
            font-size: 18px;
            font-weight: 800;
        }

        .user-text span {
            font-size: 13px;
            font-weight: 600;
        }

    .avatar {
        width: 58px;
        height: 58px;
        border: 3px solid white;
        border-radius: 50%;
        background: #d9e7ff;
        color: #1f2937;
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .avatar i {
            font-size: 32px;
        }
</style>

@code {
    [Parameter] public string Titulo { get; set; } = "";
    [Parameter] public string NombreUsuario { get; set; } = "";
    [Parameter] public string RolUsuario { get; set; } = "";

    [Parameter] public EventCallback OnToggleMenu { get; set; }

    private async Task ToggleMenu()
    {
        await OnToggleMenu.InvokeAsync();
    }
}