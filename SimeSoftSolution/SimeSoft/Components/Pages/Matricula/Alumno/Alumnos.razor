    private async Task GuardarApoderado()
    {
        errorModalApoderado = "";

        if (alumno is null)
            return;

        if (string.IsNullOrWhiteSpace(apoNombres) ||
            string.IsNullOrWhiteSpace(apoApellidoPaterno) ||
            string.IsNullOrWhiteSpace(apoDni) ||
            string.IsNullOrWhiteSpace(apoTelefono) ||
            string.IsNullOrWhiteSpace(apoCorreo) ||
            string.IsNullOrWhiteSpace(apoDireccion) ||
            string.IsNullOrWhiteSpace(apoParentesco))
        {
            errorModalApoderado = "Complete los campos obligatorios del apoderado.";
            return;
        }

        var dto = new ApoderadoNuevoRequestDto
        {
            Dni = apoDni,
            Nombres = apoNombres,
            ApellidoPaterno = apoApellidoPaterno,
            ApellidoMaterno = apoApellidoMaterno,
            Telefono = apoTelefono,
            Correo = apoCorreo,
            Direccion = apoDireccion,
            Tipo = string.IsNullOrWhiteSpace(apoTipoPersona) ? "EXTERNO" : apoTipoPersona,
            Especialidad = apoEspecialidad,
            Cargo = apoCargo,
            Area = apoArea,
            Parentesco = apoParentesco,
            ContactoEmergencia = apoContactoEmergencia,
            Observacion = apoObservacion
        };

        // apoId es el id_relacion_familiar (0 = nuevo apoderado).
        var (ok, error) = apoId == 0
            ? await ApoderadoApiService.AgregarAsync(alumno.Dni, dto)
            : await ApoderadoApiService.ActualizarAsync(apoId, dto);

        if (!ok)
        {
            errorModalApoderado = error;
            return;
        }

        await CargarDatosAlumno();

        mensaje = apoId == 0
            ? "Apoderado agregado correctamente."
            : "Apoderado actualizado correctamente.";

        mostrarModalApoderado = false;
    }

    private async Task EliminarApoderado(int id)
    {
        if (alumno is null)
            return;

        var (ok, errorEliminar) = await ApoderadoApiService.EliminarAsync(id);

        if (!ok)
        {
            error = errorEliminar;
            return;
        }

        await CargarDatosAlumno();
        mensaje = "Apoderado eliminado correctamente.";
    }

