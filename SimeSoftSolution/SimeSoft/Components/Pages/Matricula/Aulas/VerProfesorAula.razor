@page "/matricula/aulas/ver-profesores/{IdAula:int}"
@rendermode InteractiveServer

@using SimeSoft.Components.State
@using SimeSoft.Models.Aulas
@using SimeSoft.Services.Api

@inject MenuState MenuState
@inject AulaApiService AulaApiService
@inject AsignacionDocenteApiService AsignacionDocenteApiService
@inject NavigationManager Navigation

<div class="dashboard-layout">

    <SidebarMatricula MenuAbierto="@MenuState.MenuAbierto" />

    <main class="main-content">

        <Topbar Titulo="Aulas"
                NombreUsuario="Admin Favio"
                RolUsuario="Personal de Matrícula"
                OnToggleMenu="CambiarMenu" />

        <section class="content-area profesores-aula-page">

            <div class="breadcrumb-custom">
                <span>Aulas</span> / <strong>Profesores asignados</strong>
            </div>

            <div class="page-header">
                <div>
                    <h2>Profesores Asignados al Aula</h2>
                    <p>
                        Consulte, agregue, edite o elimine los docentes asignados al aula seleccionada.
                    </p>
                </div>

                <button class="btn btn-outline-secondary btn-lg fw-bold px-4"
                        @onclick="Volver">
                    <i class="bi bi-arrow-left me-2"></i>
                    Volver
                </button>
            </div>

            @if (!string.IsNullOrWhiteSpace(error))
            {
                <div class="alert alert-danger">
                    <i class="bi bi-exclamation-circle-fill me-2"></i>
                    @error
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(mensaje))
            {
                <div class="alert alert-success">
                    <i class="bi bi-check-circle-fill me-2"></i>
                    @mensaje
                </div>
            }

            @if (cargando)
            {
                <div class="alert alert-info">
                    <i class="bi bi-hourglass-split me-2"></i>
                    Cargando información desde el servicio REST...
                </div>
            }

            @if (aula is not null)
            {
                <div class="aula-summary-card">

                    <div>
                        <span>Código de aula</span>
                        <strong>@aula.Codigo</strong>
                    </div>

                    <div>
                        <span>Periodo</span>
                        <strong>@aula.Periodo</strong>
                    </div>

                    <div>
                        <span>Nivel</span>
                        <strong>@aula.Nivel</strong>
                    </div>

                    <div>
                        <span>Grado</span>
                        <strong>@aula.Grado</strong>
                    </div>

                    <div>
                        <span>Tipo</span>
                        <strong>@aula.TipoAula</strong>
                    </div>

                </div>
            }

            <div class="actions-card">
                <div>
                    <h3>Docentes asignados</h3>
                    <p>
                        Solo puede existir un tutor principal por aula.
                    </p>
                </div>

                <button class="btn btn-success btn-lg fw-bold px-4"
                        @onclick="AbrirAgregar">
                    <i class="bi bi-person-plus-fill me-2"></i>
                    Asignar profesor
                </button>
            </div>

            <div class="table-card">

                @if (!profesoresAsignados.Any())
                {
                    <div class="empty-box">
                        <i class="bi bi-person-x-fill"></i>
                        <h4>No hay profesores asignados</h4>
                        <p>Agregue un docente para esta aula.</p>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-bordered align-middle text-center">
                            <thead>
                                <tr>
                                    <th>DNI</th>
                                    <th>Profesor</th>
                                    <th>Especialidad</th>
                                    <th>Teléfono</th>
                                    <th>Correo</th>
                                    <th>Tutor</th>
                                    <th>Observación</th>
                                    <th>Estado</th>
                                    <th>Acciones</th>
                                </tr>
                            </thead>

                            <tbody>
                                @foreach (var profesor in profesoresAsignados)
                                {
                                    <tr>
                                        <td>@profesor.Dni</td>
                                        <td class="text-start fw-bold">@profesor.NombresCompletos</td>
                                        <td>@MostrarDato(profesor.Especialidad)</td>
                                        <td>@MostrarDato(profesor.Telefono)</td>
                                        <td>@MostrarDato(profesor.Correo)</td>
                                        <td>
                                            @if (profesor.EsTutor)
                                            {
                                                <span class="badge bg-success">Tutor</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary">Docente</span>
                                            }
                                        </td>
                                        <td>@MostrarDato(profesor.Observacion)</td>
                                        <td>
                                            <span class="badge bg-primary">@profesor.Estado</span>
                                        </td>
                                        <td>
                                            <button class="btn btn-primary btn-sm fw-bold me-1"
                                                    @onclick="() => AbrirEditar(profesor)">
                                                <i class="bi bi-pencil-fill"></i>
                                            </button>

                                            <button class="btn btn-danger btn-sm fw-bold"
                                                    @onclick="() => Eliminar(profesor)">
                                                <i class="bi bi-trash-fill"></i>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }

            </div>

        </section>

    </main>

</div>

@if (mostrarModal)
{
    <div class="modal-backdrop-custom profesores-modal">
        <div class="modal-profesor">

            <div class="modal-header-custom">
                <div>
                    <h3>@(modoEdicion ? "Editar asignación docente" : "Asignar profesor")</h3>
                    <p>Seleccione el profesor y configure si será tutor principal.</p>
                </div>

                <button class="btn-close-modal" @onclick="CerrarModal">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>

            @if (!string.IsNullOrWhiteSpace(errorModal))
            {
                <div class="alert alert-danger">
                    <i class="bi bi-exclamation-circle-fill me-2"></i>
                    @errorModal
                </div>
            }

            <div class="row g-3">

                <div class="col-md-12">
                    <label>Buscar profesor</label>

                    <div class="search-row">
                        <input class="form-control form-control-lg"
                               placeholder="Buscar por DNI, nombres o apellidos"
                               @bind="criterioProfesor"
                               @bind:event="oninput" />

                        <button class="btn btn-primary btn-lg fw-bold"
                                @onclick="BuscarProfesoresDisponibles">
                            <i class="bi bi-search me-2"></i>
                            Buscar
                        </button>
                    </div>
                </div>

                <div class="col-md-12">
                    <label>Profesor seleccionado</label>

                    <select class="form-select form-select-lg"
                            @bind="idPersonaSeleccionada"
                            disabled="@modoEdicion">
                        <option value="0">Seleccione un profesor...</option>

                        @foreach (var profesor in profesoresDisponibles)
                        {
                            <option value="@profesor.IdPersona">
                                @profesor.Dni - @profesor.NombresCompletos
                            </option>
                        }
                    </select>
                </div>

                <div class="col-md-12">
                    <label class="tutor-check">
                        <input type="checkbox" @bind="modalEsTutor" />

                        <div>
                            <strong>Marcar como tutor principal</strong>
                            <p>Solo puede existir un tutor principal por aula.</p>
                        </div>

                        <i class="bi bi-award-fill"></i>
                    </label>
                </div>

                <div class="col-md-12">
                    <label>Observación</label>
                    <textarea class="form-control form-control-lg"
                              rows="3"
                              maxlength="100"
                              placeholder="Ej. Tutor principal del aula"
                              @bind="modalObservacion"></textarea>
                </div>

            </div>

            <div class="modal-actions">
                <button class="btn btn-outline-secondary fw-bold px-4"
                        @onclick="CerrarModal">
                    Cancelar
                </button>

                <button class="btn btn-success fw-bold px-4"
                        @onclick="Guardar">
                    @(modoEdicion ? "Guardar cambios" : "Asignar")
                </button>
            </div>

        </div>
    </div>
}

@code {
    [Parameter]
    public int IdAula { get; set; }

    private AulaDto? aula;
    private List<ProfesorAulaDto> profesoresAsignados = new();
    private List<ProfesorAulaDto> profesoresDisponibles = new();

    private bool cargando = false;
    private string error = "";
    private string mensaje = "";

    private bool mostrarModal = false;
    private bool modoEdicion = false;
    private string errorModal = "";

    private int idAsignacionEditando = 0;
    private int idPersonaSeleccionada = 0;
    private bool modalEsTutor = false;
    private string modalObservacion = "";
    private string criterioProfesor = "";

    protected override async Task OnInitializedAsync()
    {
        await CargarDatos();
    }

    private void CambiarMenu()
    {
        MenuState.CambiarMenu();
    }

    private async Task CargarDatos()
    {
        cargando = true;
        error = "";
        mensaje = "";

        try
        {
            aula = await AulaApiService.ObtenerDetalleAsync(IdAula);
            profesoresAsignados = await AsignacionDocenteApiService.ListarPorAulaAsync(IdAula);
            profesoresDisponibles = await AsignacionDocenteApiService.ListarProfesoresDisponiblesAsync("");
        }
        catch
        {
            error = "No se pudo cargar la información de profesores del aula.";
            profesoresAsignados = new();
            profesoresDisponibles = new();
        }

        cargando = false;
    }

    private async Task BuscarProfesoresDisponibles()
    {
        errorModal = "";

        try
        {
            profesoresDisponibles =
                await AsignacionDocenteApiService.ListarProfesoresDisponiblesAsync(criterioProfesor);
        }
        catch
        {
            errorModal = "No se pudo buscar profesores disponibles.";
        }
    }

    private async Task AbrirAgregar()
    {
        modoEdicion = false;
        idAsignacionEditando = 0;
        idPersonaSeleccionada = 0;
        modalEsTutor = false;
        modalObservacion = "";
        criterioProfesor = "";
        errorModal = "";

        profesoresDisponibles =
            await AsignacionDocenteApiService.ListarProfesoresDisponiblesAsync("");

        mostrarModal = true;
    }

    private void AbrirEditar(ProfesorAulaDto profesor)
    {
        modoEdicion = true;
        idAsignacionEditando = profesor.IdAsignacionDocente;
        idPersonaSeleccionada = profesor.IdPersona;
        modalEsTutor = profesor.EsTutor;
        modalObservacion = profesor.Observacion;
        criterioProfesor = "";

        profesoresDisponibles = new List<ProfesorAulaDto> { profesor };

        errorModal = "";
        mostrarModal = true;
    }

    private async Task Guardar()
    {
        errorModal = "";
        mensaje = "";
        error = "";

        if (idPersonaSeleccionada <= 0)
        {
            errorModal = "Debe seleccionar un profesor.";
            return;
        }

        if (modalObservacion.Length > 100)
        {
            errorModal = "La observación no debe superar los 100 caracteres.";
            return;
        }

        var request = new AsignacionDocenteRequestDto
        {
            IdPersona = idPersonaSeleccionada,
            IdAula = IdAula,
            IdMatriculaCabecera = aula?.IdMatriculaCabecera,
            EsTutor = modalEsTutor,
            Observacion = modalObservacion
        };

        bool ok;

        if (modoEdicion)
        {
            ok = await AsignacionDocenteApiService.ActualizarAsync(idAsignacionEditando, request);
        }
        else
        {
            ok = await AsignacionDocenteApiService.AsignarAsync(request);
        }

        if (!ok)
        {
            errorModal = "No se pudo guardar la asignación. Revise si ya existe el profesor o tutor.";
            return;
        }

        mensaje = modoEdicion
            ? "Asignación actualizada correctamente."
            : "Profesor asignado correctamente.";

        mostrarModal = false;
        await CargarDatos();
    }

    private async Task Eliminar(ProfesorAulaDto profesor)
    {
        mensaje = "";
        error = "";

        bool ok = await AsignacionDocenteApiService.EliminarAsync(profesor.IdAsignacionDocente);

        if (!ok)
        {
            error = "No se pudo eliminar la asignación docente.";
            return;
        }

        mensaje = "Asignación eliminada correctamente.";
        await CargarDatos();
    }

    private void CerrarModal()
    {
        mostrarModal = false;
        errorModal = "";
    }

    private void Volver()
    {
        Navigation.NavigateTo("/matricula/aulas/administrar");
    }

    private string MostrarDato(string? valor)
    {
        return string.IsNullOrWhiteSpace(valor) ? "-" : valor;
    }
}