@page "/matricula/aulas/ver-profesores"
@rendermode InteractiveServer

@using SimeSoft.Components.State
@inject MenuState MenuState
@inject AulaState AulaState
@inject NavigationManager Navigation

<div class="dashboard-layout">

    <SidebarMatricula MenuAbierto="@MenuState.MenuAbierto" />

    <main class="main-content">

        <Topbar Titulo="Profesores del Aula"
                NombreUsuario="Admin Favio"
                RolUsuario="Administrador"
                OnToggleMenu="CambiarMenu" />

        <section class="content-area">

            <div class="breadcrumb-custom">
                <span>Aulas</span> / <span>Administrar</span> / <strong>Profesores del Aula</strong>
            </div>

            @if (aula is null)
            {
                <div class="alert alert-warning">
                    No se seleccionó ningún aula.
                </div>

                <button class="btn btn-outline-secondary fw-bold px-4"
                        @onclick="Volver">
                    <i class="bi bi-arrow-left me-2"></i>
                    Volver
                </button>
            }
            else
            {
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div>
                        <h2>Profesores del Aula</h2>

                        <p class="page-description">
                            Desde esta pantalla puedes ver, asignar, editar o quitar profesores del aula seleccionada.
                        </p>
                    </div>

                    <button class="btn btn-outline-secondary fw-bold px-4"
                            @onclick="Volver">
                        <i class="bi bi-arrow-left me-2"></i>
                        Volver
                    </button>
                </div>

                @if (!string.IsNullOrWhiteSpace(mensaje))
                {
                    <div class="alert alert-success">
                        <i class="bi bi-check-circle-fill me-2"></i>
                        @mensaje
                    </div>
                }

                @if (!string.IsNullOrWhiteSpace(error))
                {
                    <div class="alert alert-warning">
                        <i class="bi bi-exclamation-circle-fill me-2"></i>
                        @error
                    </div>
                }

                <div class="readonly-card">

                    <div>
                        <span>Periodo</span>
                        <strong>@aula.Periodo</strong>
                    </div>

                    <div>
                        <span>Nivel</span>
                        <strong>@(aula.EsCompartida ? "Todos" : aula.Nivel)</strong>
                    </div>

                    <div>
                        <span>Grado</span>
                        <strong>@(aula.EsCompartida ? "Todos" : aula.Grado)</strong>
                    </div>

                    <div>
                        <span>Aula</span>
                        <strong>@aula.Codigo</strong>
                    </div>

                    <div>
                        <span>Tipo</span>
                        <strong>@aula.TipoAula</strong>
                    </div>

                    <div>
                        <span>Capacidad</span>
                        <strong>@aula.Capacidad</strong>
                    </div>

                    <div>
                        <span>Ocupadas</span>
                        <strong class="text-warning">@aula.VacantesOcupadas</strong>
                    </div>

                    <div>
                        <span>Disponibles</span>
                        <strong class="text-success">@aula.VacantesDisponibles</strong>
                    </div>

                </div>

                <div class="row g-4 mt-2">

                    <div class="col-lg-7">
                        <div class="panel-card">

                            <h3>
                                <i class="bi bi-people-fill me-2"></i>
                                Profesores asignados
                            </h3>

                            <div class="table-responsive mt-3">
                                <table class="table table-bordered text-center align-middle mb-0">

                                    <thead>
                                        <tr>
                                            <th>DNI</th>
                                            <th>Profesor</th>
                                            <th>Especialidad</th>
                                            <th>Teléfono</th>
                                            <th>Correo</th>
                                            <th>¿Tutor?</th>
                                            <th>Observación</th>
                                            <th>Estado</th>
                                            <th>Acciones</th>
                                        </tr>
                                    </thead>

                                    <tbody>
                                        @foreach (var profesor in profesoresAsignados)
                                        {
                                            <tr>
                                                <td>@profesor.Dni</td>

                                                <td>@profesor.NombreCompleto</td>

                                                <td>@profesor.Especialidad</td>

                                                <td>@profesor.Telefono</td>

                                                <td>@profesor.Correo</td>

                                                <td>
                                                    @if (profesor.EsTutor)
                                                    {
                                                        <span class="badge bg-success-subtle text-success">
                                                            Sí
                                                        </span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge bg-light text-dark border">
                                                            No
                                                        </span>
                                                    }
                                                </td>

                                                <td>@profesor.Observacion</td>

                                                <td>
                                                    <span class="badge bg-success-subtle text-success">
                                                        @profesor.Estado
                                                    </span>
                                                </td>

                                                <td>
                                                    <button class="btn btn-link text-primary fw-bold text-decoration-none"
                                                            disabled="@(aula.Periodo != "2026")"
                                                            @onclick="() => AbrirEditarAsignacion(profesor)">
                                                        <i class="bi bi-pencil-fill me-1"></i>
                                                        Editar
                                                    </button>

                                                    <button class="btn btn-link text-danger fw-bold text-decoration-none"
                                                            @onclick="() => QuitarAsignacion(profesor.Id)">
                                                        <i class="bi bi-trash-fill me-1"></i>
                                                        Quitar
                                                    </button>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>

                                </table>
                            </div>

                            @if (!profesoresAsignados.Any())
                            {
                                <div class="alert alert-warning mt-3">
                                    Esta aula todavía no tiene profesores asignados.
                                </div>
                            }

                            <div class="info-box mt-3">
                                <i class="bi bi-info-circle-fill"></i>

                                <div>
                                    Solo se puede editar la asignación en el periodo actual 2026.
                                    Para periodos antiguos solo se puede consultar o quitar la asignación si el administrador lo permite.
                                </div>
                            </div>

                        </div>
                    </div>

                    <div class="col-lg-5">
                        <div class="panel-card">

                            <h3>
                                <i class="bi bi-person-plus-fill me-2"></i>
                                Asignar profesor
                            </h3>

                            <label>Buscar profesor</label>

                            <input class="form-control mb-3"
                                   placeholder="Buscar por DNI, nombre o especialidad"
                                   @bind="criterioProfesor"
                                   @bind:event="oninput" />

                            @if (string.IsNullOrWhiteSpace(criterioProfesor))
                            {
                                <div class="alert alert-info py-2">
                                    Escribe un DNI, nombre o especialidad para buscar profesores.
                                </div>
                            }
                            else
                            {
                                <div class="table-responsive">
                                    <table class="table table-bordered text-center align-middle mb-0">

                                        <thead>
                                            <tr>
                                                <th>DNI</th>
                                                <th>Profesor</th>
                                                <th>Especialidad</th>
                                                <th></th>
                                            </tr>
                                        </thead>

                                        <tbody>
                                            @foreach (var profesor in ProfesoresEncontrados)
                                            {
                                                <tr>
                                                    <td>@profesor.Dni</td>

                                                    <td>@profesor.NombreCompleto</td>

                                                    <td>@profesor.Especialidad</td>

                                                    <td>
                                                        <input type="radio"
                                                               name="profesorSeleccionado"
                                                               @onchange="() => profesorSeleccionado = profesor" />
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>

                                    </table>
                                </div>

                                @if (!ProfesoresEncontrados.Any())
                                {
                                    <div class="alert alert-warning mt-3">
                                        No se encontraron profesores con ese criterio.
                                    </div>
                                }
                            }

                            <div class="form-check mt-3">
                                <input class="form-check-input"
                                       type="checkbox"
                                       @bind="nuevoEsTutor" />

                                <label class="form-check-label fw-bold">
                                    Marcar como tutor del aula
                                </label>
                            </div>

                            <small class="text-muted">
                                Solo puede haber un tutor por aula. Si marcas esta opción, se reemplazará al tutor anterior.
                            </small>

                            <div class="mt-3">
                                <label>Observación</label>

                                <textarea class="form-control"
                                          rows="3"
                                          maxlength="200"
                                          placeholder="Ej.: Tutor del aula, enseña matemática, encargado del laboratorio, etc."
                                          @bind="nuevaObservacion"></textarea>
                            </div>

                            <div class="d-grid gap-3 mt-3">

                                <button class="btn btn-primary btn-lg fw-bold"
                                        @onclick="AsignarProfesor">
                                    <i class="bi bi-person-plus-fill me-2"></i>
                                    Asignar profesor
                                </button>

                                <button class="btn btn-outline-secondary btn-lg fw-bold"
                                        @onclick="LimpiarAsignacion">
                                    Limpiar
                                </button>

                            </div>

                        </div>
                    </div>

                </div>
            }

        </section>

    </main>

</div>

@if (asignacionEditando is not null)
{
    <div class="modal-backdrop-custom">

        <div class="modal-editar">

            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <h3>Editar asignación</h3>

                    <p class="mb-0">
                        @asignacionEditando.NombreCompleto
                    </p>
                </div>

                <button class="btn-close" @onclick="CancelarEdicion"></button>
            </div>

            <hr />

            <div class="form-check mb-3">
                <input class="form-check-input"
                       type="checkbox"
                       @bind="editarEsTutor" />

                <label class="form-check-label fw-bold">
                    Es tutor del aula
                </label>
            </div>

            <div>
                <label>Observación</label>

                <textarea class="form-control"
                          rows="3"
                          maxlength="200"
                          @bind="editarObservacion"></textarea>
            </div>

            <div class="modal-actions">
                <button class="btn btn-primary fw-bold px-4"
                        @onclick="GuardarEdicion">
                    Guardar
                </button>

                <button class="btn btn-outline-secondary fw-bold px-4"
                        @onclick="CancelarEdicion">
                    Cancelar
                </button>
            </div>

        </div>

    </div>
}

@code {
    private AulaModel? aula;

    private List<ProfesorAulaModel> profesoresAsignados = new();

    private string criterioProfesor = "";

    private ProfesorDisponibleModel? profesorSeleccionado;

    private bool nuevoEsTutor = false;

    private string nuevaObservacion = "";

    private ProfesorAulaModel? asignacionEditando;

    private bool editarEsTutor = false;

    private string editarObservacion = "";

    private string mensaje = "";

    private string error = "";

    private IEnumerable<ProfesorDisponibleModel> ProfesoresEncontrados =>
        AulaState.BuscarProfesoresDisponibles(criterioProfesor);

    protected override void OnInitialized()
    {
        aula = AulaState.AulaSeleccionada;

        CargarProfesoresAsignados();
    }

    private void CambiarMenu()
    {
        MenuState.CambiarMenu();
    }

    private void CargarProfesoresAsignados()
    {
        if (aula is null)
        {
            profesoresAsignados = new List<ProfesorAulaModel>();
            return;
        }

        profesoresAsignados = AulaState.ObtenerProfesoresPorAula(aula.Id);
    }

    private void AsignarProfesor()
    {
        mensaje = "";
        error = "";

        if (aula is null)
        {
            error = "No se seleccionó ningún aula.";
            return;
        }

        if (profesorSeleccionado is null)
        {
            error = "Debe seleccionar un profesor para asignarlo al aula.";
            return;
        }

        bool yaExiste = profesoresAsignados.Any(p => p.Dni == profesorSeleccionado.Dni);

        if (yaExiste)
        {
            error = "El profesor ya está asignado a esta aula.";
            return;
        }

        AulaState.AsignarProfesor(
            aula.Id,
            profesorSeleccionado,
            nuevoEsTutor,
            nuevaObservacion
        );

        mensaje = "Profesor asignado correctamente.";

        LimpiarAsignacion();

        CargarProfesoresAsignados();
    }

    private void AbrirEditarAsignacion(ProfesorAulaModel profesor)
    {
        asignacionEditando = profesor;
        editarEsTutor = profesor.EsTutor;
        editarObservacion = profesor.Observacion;
    }

    private void GuardarEdicion()
    {
        mensaje = "";
        error = "";

        if (asignacionEditando is null)
        {
            return;
        }

        AulaState.EditarAsignacion(
            asignacionEditando.Id,
            editarEsTutor,
            editarObservacion
        );

        mensaje = "Asignación actualizada correctamente.";

        asignacionEditando = null;

        CargarProfesoresAsignados();
    }

    private void QuitarAsignacion(int id)
    {
        mensaje = "";
        error = "";

        AulaState.QuitarAsignacion(id);

        mensaje = "Asignación eliminada correctamente.";

        CargarProfesoresAsignados();
    }

    private void LimpiarAsignacion()
    {
        criterioProfesor = "";
        profesorSeleccionado = null;
        nuevoEsTutor = false;
        nuevaObservacion = "";
    }

    private void CancelarEdicion()
    {
        asignacionEditando = null;
    }

    private void Volver()
    {
        Navigation.NavigateTo("/matricula/aulas/administrar");
    }
}