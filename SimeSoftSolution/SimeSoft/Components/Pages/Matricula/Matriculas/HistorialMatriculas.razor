@page "/matricula/matriculas/historial"
@rendermode InteractiveServer

@using SimeSoft.Components.State
@using Microsoft.JSInterop
@inject MenuState MenuState
@inject MatriculaState MatriculaState
@inject IJSRuntime JS

<div class="dashboard-layout">

    <SidebarMatricula MenuAbierto="@MenuState.MenuAbierto" />

    <main class="main-content">

        <Topbar Titulo="Historial"
                NombreUsuario="Admin Favio"
                RolUsuario="Personal de Matrícula"
                OnToggleMenu="CambiarMenu" />

        <section class="content-area historial-page">

            <div class="historial-header no-print">
                <div>
                    <div class="breadcrumb-custom">
                        <span>Matrículas</span> / <strong>Historial</strong>
                    </div>

                    <h2>Historial de Alumnos Matriculados</h2>

                    <p>
                        Este apartado sirve como reporte para filtrar por periodo, nivel, grado e impresión.
                    </p>
                </div>

                <button class="btn btn-primary btn-lg fw-bold px-4"
                        @onclick="Imprimir">
                    <i class="bi bi-printer-fill me-2"></i>
                    Imprimir
                </button>
            </div>

            <div class="filters-card no-print">

                <div class="row g-3">

                   

                    <div class="row g-3">

                        <div class="col-md-4">
                            <label>Periodo</label>
                            <select class="form-select form-select-lg"
                                    @bind="periodoSeleccionado">
                                <option value="">Todos</option>

                                @foreach (var periodo in PeriodosDisponibles)
                                {
                                    <option value="@periodo">@periodo</option>
                                }
                            </select>
                        </div>

                        <div class="col-md-4">
                            <label>Nivel</label>
                            <select class="form-select form-select-lg"
                                    @bind="nivelSeleccionado">
                                <option value="">Todos</option>
                                <option value="Inicial">Inicial</option>
                                <option value="Primaria">Primaria</option>
                                <option value="Secundaria">Secundaria</option>
                            </select>
                        </div>

                        <div class="col-md-4">
                            <label>Grado</label>
                            <select class="form-select form-select-lg"
                                    @bind="gradoSeleccionado">
                                <option value="">Todos</option>

                                @foreach (var grado in GradosDisponibles)
                                {
                                    <option value="@grado">@grado</option>
                                }
                            </select>
                        </div>

                    </div>

                </div>

                <div class="filter-actions">
                    <button class="btn btn-outline-secondary fw-bold px-4"
                            @onclick="LimpiarFiltros">
                        <i class="bi bi-eraser-fill me-2"></i>
                        Limpiar filtros
                    </button>
                </div>

            </div>

            <div class="summary-grid no-print">

                <div class="summary-card">
                    <span>Total matriculados</span>
                    <strong>@RegistrosFiltrados.Count</strong>
                </div>

                <div class="summary-card">
                    <span>Periodo</span>
                    <strong>@(string.IsNullOrWhiteSpace(periodoSeleccionado) ? "Todos" : periodoSeleccionado)</strong>
                </div>

                <div class="summary-card">
                    <span>Nivel</span>
                    <strong>@(string.IsNullOrWhiteSpace(nivelSeleccionado) ? "Todos" : nivelSeleccionado)</strong>
                </div>

                <div class="summary-card">
                    <span>Grado</span>
                    <strong>@(string.IsNullOrWhiteSpace(gradoSeleccionado) ? "Todos" : gradoSeleccionado)</strong>
                </div>

            </div>

            <div class="print-title">
                <h2>Reporte de Alumnos Matriculados</h2>
                <p>Fecha de impresión: @DateTime.Now.ToString("dd/MM/yyyy HH:mm")</p>
            </div>

            <div class="table-card">

                <div class="table-header no-print">
                    <div>
                        <h3>Lista de matrículas</h3>
                        <p>
                            Mostrando @RegistrosPaginados.Count de @RegistrosFiltrados.Count registros.
                        </p>
                    </div>

                    <div class="page-size-box">
                        <label>Filas por página</label>
                        <select class="form-select"
                                @bind="FilasPorPagina">
                            <option value="5">5</option>
                            <option value="10">10</option>
                            <option value="15">15</option>
                            <option value="20">20</option>
                        </select>
                    </div>
                </div>

                @if (!RegistrosFiltrados.Any())
                {
                    <div class="empty-box">
                        <i class="bi bi-inbox-fill"></i>
                        <h4>No hay alumnos matriculados</h4>
                        <p>No se encontraron registros con los filtros seleccionados.</p>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-bordered align-middle text-center">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>DNI</th>
                                    <th>Alumno</th>
                                    <th>Periodo</th>
                                    <th>Nivel</th>
                                    <th>Grado</th>
                                    <th>Aula</th>
                                    <th>Fecha matrícula</th>
                                    <th>Estado</th>
                                    <th class="no-print">Acción</th>
                                </tr>
                            </thead>

                            <tbody>
                                @foreach (var item in RegistrosPaginados)
                                {
                                    <tr>
                                        <td>@item.Id</td>
                                        <td>@item.Dni</td>
                                        <td class="text-start fw-bold">@item.NombresCompletos</td>
                                        <td>@item.Periodo</td>
                                        <td>@item.Nivel</td>
                                        <td>@item.Grado</td>
                                        <td>@item.Aula</td>
                                        <td>@item.FechaMatricula.ToString("dd/MM/yyyy")</td>
                                        <td>
                                            <span class="badge bg-success">
                                                @item.Estado
                                            </span>
                                        </td>
                                        <td class="no-print">
                                            <button class="btn btn-danger btn-sm fw-bold"
                                                    @onclick="() => AbrirConfirmacionEliminar(item)">
                                                <i class="bi bi-trash-fill me-1"></i>
                                                Eliminar
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <div class="pagination-box no-print">
                        <button class="btn btn-outline-primary fw-bold"
                                disabled="@(paginaActual == 1)"
                                @onclick="PaginaAnterior">
                            <i class="bi bi-chevron-left"></i>
                            Anterior
                        </button>

                        <span>
                            Página <strong>@paginaActual</strong> de <strong>@TotalPaginas</strong>
                        </span>

                        <button class="btn btn-outline-primary fw-bold"
                                disabled="@(paginaActual == TotalPaginas)"
                                @onclick="PaginaSiguiente">
                            Siguiente
                            <i class="bi bi-chevron-right"></i>
                        </button>
                    </div>
                }

            </div>

        </section>

    </main>

</div>

@if (mostrarConfirmacionEliminar && registroSeleccionado is not null)
{
    <div class="modal-backdrop-custom historial-modal">
        <div class="modal-confirmacion">

            <div class="modal-icon danger">
                <i class="bi bi-trash-fill"></i>
            </div>

            <h3>Eliminar matrícula del historial</h3>

            <p>
                ¿Está seguro de eliminar del historial al alumno
                <strong>@registroSeleccionado.NombresCompletos</strong>?
            </p>

            <div class="modal-actions">
                <button class="btn btn-outline-secondary fw-bold px-4"
                        @onclick="CerrarConfirmacionEliminar">
                    Cancelar
                </button>

                <button class="btn btn-danger fw-bold px-4"
                        @onclick="ConfirmarEliminar">
                    Eliminar
                </button>
            </div>

        </div>
    </div>
}

@code {
    
    private string periodoSeleccionado = "";
    private string nivelSeleccionado = "";
    private string gradoSeleccionado = "";

    private int paginaActual = 1;
    private int filasPorPagina = 10;

    private bool mostrarConfirmacionEliminar = false;
    private HistorialMatriculaModel? registroSeleccionado;

    private int FilasPorPagina
    {
        get => filasPorPagina;
        set
        {
            filasPorPagina = value;
            paginaActual = 1;
        }
    }

    private List<string> PeriodosDisponibles =>
        MatriculaState.HistorialMatriculas
            .Where(h => h.Activo)
            .Select(h => h.Periodo)
            .Distinct()
            .OrderByDescending(p => p)
            .ToList();

    private List<string> GradosDisponibles =>
        nivelSeleccionado switch
        {
            "Inicial" => new List<string> { "3 AÑOS", "4 AÑOS", "5 AÑOS" },
            "Primaria" => new List<string> { "1°", "2°", "3°", "4°", "5°", "6°" },
            "Secundaria" => new List<string> { "1°", "2°", "3°", "4°", "5°" },
            _ => MatriculaState.HistorialMatriculas
                    .Where(h => h.Activo)
                    .Select(h => h.Grado)
                    .Distinct()
                    .OrderBy(g => g)
                    .ToList()
        };

    private List<HistorialMatriculaModel> RegistrosFiltrados =>
     MatriculaState.HistorialMatriculas
         .Where(h => h.Activo)
         .Where(h =>
             string.IsNullOrWhiteSpace(periodoSeleccionado) ||
             h.Periodo.Equals(periodoSeleccionado, StringComparison.OrdinalIgnoreCase))
         .Where(h =>
             string.IsNullOrWhiteSpace(nivelSeleccionado) ||
             h.Nivel.Equals(nivelSeleccionado, StringComparison.OrdinalIgnoreCase))
         .Where(h =>
             string.IsNullOrWhiteSpace(gradoSeleccionado) ||
             h.Grado.Equals(gradoSeleccionado, StringComparison.OrdinalIgnoreCase))
         .OrderByDescending(h => h.FechaMatricula)
         .ThenBy(h => h.Nivel)
         .ThenBy(h => h.Grado)
         .ThenBy(h => h.NombresCompletos)
         .ToList();

    private int TotalPaginas =>
        RegistrosFiltrados.Count == 0
            ? 1
            : (int)Math.Ceiling(RegistrosFiltrados.Count / (double)filasPorPagina);

    private List<HistorialMatriculaModel> RegistrosPaginados
    {
        get
        {
            if (paginaActual > TotalPaginas)
            {
                paginaActual = TotalPaginas;
            }

            return RegistrosFiltrados
                .Skip((paginaActual - 1) * filasPorPagina)
                .Take(filasPorPagina)
                .ToList();
        }
    }

    private void CambiarMenu()
    {
        MenuState.CambiarMenu();
    }

    private void LimpiarFiltros()
    {
        periodoSeleccionado = "";
        nivelSeleccionado = "";
        gradoSeleccionado = "";
        paginaActual = 1;
    }

    private void PaginaAnterior()
    {
        if (paginaActual > 1)
        {
            paginaActual--;
        }
    }

    private void PaginaSiguiente()
    {
        if (paginaActual < TotalPaginas)
        {
            paginaActual++;
        }
    }

    private void AbrirConfirmacionEliminar(HistorialMatriculaModel registro)
    {
        registroSeleccionado = registro;
        mostrarConfirmacionEliminar = true;
    }

    private void CerrarConfirmacionEliminar()
    {
        registroSeleccionado = null;
        mostrarConfirmacionEliminar = false;
    }

    private void ConfirmarEliminar()
    {
        if (registroSeleccionado is not null)
        {
            MatriculaState.EliminarHistorialMatricula(registroSeleccionado.Id);
        }

        CerrarConfirmacionEliminar();

        if (paginaActual > TotalPaginas)
        {
            paginaActual = TotalPaginas;
        }
    }

    private async Task Imprimir()
    {
        await JS.InvokeVoidAsync("window.print");
    }
}